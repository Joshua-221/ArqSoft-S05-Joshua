@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="error-screen">
    <section class="error-card">
        <div class="error-badge">
            <svg class="ui-icon" aria-hidden="true"><use href="#icon-warning"></use></svg>
            Error del sistema
        </div>

        <h1 class="error-title">Algo falló al procesar la solicitud</h1>
        <p class="error-copy">
            La aplicación no pudo completar la acción. Vuelve al inicio o abre la agenda para seguir navegando.
        </p>

        <div class="error-actions">
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary d-inline-flex align-items-center gap-2">
                <svg class="ui-icon" aria-hidden="true"><use href="#icon-home"></use></svg>
                Ir al inicio
            </a>
            <a asp-controller="Cita" asp-action="Index" class="btn btn-secondary d-inline-flex align-items-center gap-2">
                <svg class="ui-icon" aria-hidden="true"><use href="#icon-calendar"></use></svg>
                Abrir agenda
            </a>
        </div>

        @if (Model.ShowRequestId)
        {
            <div class="request-card">
                <strong>Request ID:</strong> <code>@Model.RequestId</code>
            </div>
        }
    </section>
</div>
