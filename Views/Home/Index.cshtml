@{
    ViewData["Title"] = "CitasApp - Panel clínico";

    var totalCitas = ViewBag.TotalCitas is int tc ? tc : 0;
    var pendientes = ViewBag.Pendientes is int pe ? pe : 0;
    var confirmadas = ViewBag.Confirmadas is int co ? co : 0;
    var totalPacientes = ViewBag.TotalPacientes is int tp ? tp : 0;
    var totalMedicos = ViewBag.TotalMedicos is int tm ? tm : 0;
    var proximaCita = ViewBag.ProximaCita as Cita;
    var proximoPaciente = ViewBag.ProximaPaciente as Paciente;
    var proximoMedico = ViewBag.ProximoMedico as Medico;
}

<div class="home-dashboard">
    <section class="hero-panel">
        <div class="hero-grid">
            <div class="hero-copy">
                <span class="eyebrow">
                    <svg class="ui-icon" aria-hidden="true"><use href="#icon-spark"></use></svg>
                    Panel clínico renovado
                </span>
                <h1>Gestiona tu agenda </h1>
                <p>
                    Consulta citas, pacientes y médicos desde un tablero más limpio, con accesos rápidos,
                    mejores transiciones y una lectura visual mucho más clara.
                </p>

                <div class="hero-actions">
                    <a asp-controller="Cita" asp-action="Create" class="btn btn-primary d-inline-flex align-items-center gap-2">
                        <svg class="ui-icon" aria-hidden="true"><use href="#icon-plus"></use></svg>
                        Nueva cita
                    </a>
                    <a asp-controller="Cita" asp-action="Index" class="btn btn-outline-primary d-inline-flex align-items-center gap-2">
                        <svg class="ui-icon" aria-hidden="true"><use href="#icon-calendar"></use></svg>
                        Ver agenda
                    </a>
                </div>
            </div>

            <aside class="hero-stats" aria-label="Resumen general">
                <div class="stat-tile">
                    <span class="stat-label">Citas totales</span>
                    <div class="stat-value">@totalCitas</div>
                </div>
                <div class="stat-tile">
                    <span class="stat-label">Pendientes</span>
                    <div class="stat-value">@pendientes</div>
                </div>
                <div class="stat-tile">
                    <span class="stat-label">Confirmadas</span>
                    <div class="stat-value">@confirmadas</div>
                </div>
                <div class="next-card">
                    <span class="stat-label">Próxima cita</span>
                    @if (proximaCita != null)
                    {
                        <h3>
                            @(proximoPaciente != null ? $"{proximoPaciente.Nombre} {proximoPaciente.Apellido}" : "Paciente no disponible")
                        </h3>
                        <p>
                            @proximaCita.Fecha.ToString("dd/MM/yyyy") - @proximaCita.Hora.ToString("HH:mm")
                            <br />
                            @(proximoMedico != null ? $"{proximoMedico.Nombre} {proximoMedico.Apellido}" : "Médico no disponible")
                        </p>
                    }
                    else
                    {
                        <h3>Sin citas registradas</h3>
                        <p>Crea una nueva cita para empezar a usar el panel.</p>
                    }
                </div>
            </aside>
        </div>
    </section>

    <section class="module-grid" aria-label="Accesos principales">
        <a asp-controller="Cita" asp-action="Index" class="module-card">
            <div class="module-icon">
                <svg aria-hidden="true"><use href="#icon-calendar"></use></svg>
            </div>
            <h2>Agenda</h2>
            <p>Revisa el estado de las citas y accede al detalle completo de cada registro.</p>
            <div class="module-link">
                Abrir agenda
                <svg aria-hidden="true"><use href="#icon-arrow-right"></use></svg>
            </div>
        </a>

        <a asp-controller="Paciente" asp-action="Index" class="module-card">
            <div class="module-icon">
                <svg aria-hidden="true"><use href="#icon-users"></use></svg>
            </div>
            <h2>Pacientes</h2>
            <p>Mantén la base de pacientes ordenada y revisa sus datos en segundos.</p>
            <div class="module-link">
                @totalPacientes pacientes
                <svg aria-hidden="true"><use href="#icon-arrow-right"></use></svg>
            </div>
        </a>

        <a asp-controller="Medico" asp-action="Index" class="module-card">
            <div class="module-icon">
                <svg aria-hidden="true"><use href="#icon-pulse"></use></svg>
            </div>
            <h2>Médicos</h2>
            <p>Consulta especialidades y disponibilidad sin salir del panel.</p>
            <div class="module-link">
                @totalMedicos médicos
                <svg aria-hidden="true"><use href="#icon-arrow-right"></use></svg>
            </div>
        </a>

        <a asp-controller="Cita" asp-action="Create" class="module-card featured">
            <div class="module-icon">
                <svg aria-hidden="true"><use href="#icon-plus"></use></svg>
            </div>
            <h2>Nueva cita</h2>
            <p>Agenda una consulta rápida con el nuevo flujo de captura.</p>
            <div class="module-link">
                Crear ahora
                <svg aria-hidden="true"><use href="#icon-arrow-right"></use></svg>
            </div>
        </a>
    </section>

    <section class="info-grid">
        <article class="info-panel">
            <span class="panel-kicker">
                <svg class="ui-icon" aria-hidden="true"><use href="#icon-shield"></use></svg>
                Flujo estable
            </span>
            <h2>Una interfaz más limpia y consistente</h2>
            <p>
                El nuevo tema usa fondos suaves, cards con glass effect y transiciones más controladas para que
                cada sección se sienta conectada sin perder velocidad.
            </p>
            <a asp-controller="Cita" asp-action="Index" class="panel-link">
                Ir a citas
                <svg aria-hidden="true"><use href="#icon-arrow-right"></use></svg>
            </a>
        </article>

        <aside class="status-card">
            <div class="status-row">
                <span class="status-dot pending"></span>
                <div>
                    <strong>@pendientes pendientes</strong>
                    <small>Requieren confirmación o seguimiento</small>
                </div>
            </div>
            <div class="status-row">
                <span class="status-dot confirmed"></span>
                <div>
                    <strong>@confirmadas confirmadas</strong>
                    <small>Listas para atención</small>
                </div>
            </div>
            <div class="status-row">
                <span class="status-dot canceled"></span>
                <div>
                    <strong>Cancelaciones controladas</strong>
                    <small>El sistema mantiene el historial visible</small>
                </div>
            </div>
        </aside>
    </section>

    <section class="trust-strip" aria-label="Beneficios del sistema">
        <div class="trust-item">
            <strong>Datos limpios</strong>
            <span>Pacientes y médicos con información actualizada</span>
        </div>
        <div class="trust-item">
            <strong>Accesos rápidos</strong>
            <span>Botones directos a agenda, pacientes y médicos</span>
        </div>
        <div class="trust-item">
            <strong>Transiciones suaves</strong>
            <span>Cards y botones con interacción más fluida</span>
        </div>
    </section>
</div>
