@model IEnumerable<CitasApp.Models.Cita>
@using CitasApp.Models

@{
    ViewData["Title"] = "Agenda";
    var pacientes = ViewBag.Pacientes as IEnumerable<Paciente> ?? Enumerable.Empty<Paciente>();
    var medicos = ViewBag.Medicos as IEnumerable<Medico> ?? Enumerable.Empty<Medico>();
}

<div class="page-header">
    <div>
        <h1>Agenda de citas</h1>
        <p>@(Model?.Count() ?? 0) cita(s) registrada(s)</p>
    </div>
    <a asp-action="Create" class="btn btn-success d-inline-flex align-items-center gap-2">
        <svg class="ui-icon" aria-hidden="true"><use href="#icon-plus"></use></svg>
        Nueva cita
    </a>
</div>

<div class="card-box">
    @if (Model?.Any() == true)
    {
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Paciente</th>
                        <th>Médico</th>
                        <th>Fecha</th>
                        <th>Hora</th>
                        <th>Asunto del paciente</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cita in Model)
                    {
                        var paciente = pacientes.FirstOrDefault(p => p.Id == cita.PacienteId);
                        var medico = medicos.FirstOrDefault(m => m.Id == cita.MedicoId);
                        var estadoColor = cita.Estado == "Confirmada" ? "#16a34a" : cita.Estado == "Cancelada" ? "#dc2626" : "#d97706";

                        <tr>
                            <td>
                                <strong>@(paciente != null ? $"{paciente.Nombre} {paciente.Apellido}" : "Paciente no encontrado")</strong>
                            </td>
                            <td>@(medico != null ? $"{medico.Nombre} {medico.Apellido}" : "Médico no encontrado")</td>
                            <td>@cita.Fecha.ToString("dd/MM/yyyy")</td>
                            <td>@cita.Hora.ToString("HH:mm")</td>
                            <td>@(string.IsNullOrWhiteSpace(cita.Asunto) ? "—" : cita.Asunto)</td>
                            <td>
                                <span class="badge" style="background:@(estadoColor)18;color:@estadoColor;">
                                    @cita.Estado
                                </span>
                            </td>
                            <td>
                                <div class="d-flex flex-wrap gap-2">
                                    <a asp-action="Detalle" asp-route-id="@cita.Id" class="btn btn-info btn-sm">Ver</a>
                                    <a asp-action="Edit" asp-route-id="@cita.Id" class="btn btn-warning btn-sm">Editar</a>
                                    <form asp-action="Delete" asp-route-id="@cita.Id" method="post" class="d-inline">
                                        <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('¿Eliminar esta cita?')">
                                            Eliminar
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <svg class="ui-icon ui-icon-lg text-muted" aria-hidden="true"><use href="#icon-calendar"></use></svg>
            <h3 class="mt-3">No hay citas registradas</h3>
            <p class="text-muted mb-4">Crea la primera cita para empezar a usar la agenda.</p>
            <a asp-action="Create" class="btn btn-primary d-inline-flex align-items-center gap-2">
                <svg class="ui-icon" aria-hidden="true"><use href="#icon-plus"></use></svg>
                Crear primera cita
            </a>
        </div>
    }
</div>
