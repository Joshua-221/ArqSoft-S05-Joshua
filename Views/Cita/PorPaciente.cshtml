@model IEnumerable<CitasApp.Models.Cita>
@using CitasApp.Models

@{
    ViewData["Title"] = "Citas por paciente";
    var paciente = ViewBag.Paciente as Paciente;
    var medicos = ViewBag.Medicos as IEnumerable<Medico> ?? Enumerable.Empty<Medico>();
}

<div class="page-header">
    <div>
        <h1>Citas de @(paciente != null ? $"{paciente.Nombre} {paciente.Apellido}" : "paciente")</h1>
        <p>Historial de citas asociado al paciente seleccionado.</p>
    </div>
    <a asp-action="Index" class="btn btn-secondary">Ver todas las citas</a>
</div>

<div class="card-box">
    @if (Model?.Any() == true)
    {
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Fecha</th>
                        <th>Hora</th>
                        <th>Médico</th>
                        <th>Asunto del paciente</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cita in Model)
                    {
                        var medico = medicos.FirstOrDefault(m => m.Id == cita.MedicoId);
                        var estadoColor = cita.Estado == "Confirmada" ? "#16a34a" : cita.Estado == "Cancelada" ? "#dc2626" : "#d97706";

                        <tr>
                            <td>@cita.Fecha.ToString("dd/MM/yyyy")</td>
                            <td>@cita.Hora.ToString("HH:mm")</td>
                            <td>@(medico != null ? $"{medico.Nombre} {medico.Apellido}" : "Médico no encontrado")</td>
                            <td>@(string.IsNullOrWhiteSpace(cita.Asunto) ? "—" : cita.Asunto)</td>
                            <td>
                                <span class="badge" style="background:@(estadoColor)18;color:@estadoColor;">
                                    @cita.Estado
                                </span>
                            </td>
                            <td>
                                <div class="d-flex flex-wrap gap-2">
                                    <a asp-action="Detalle" asp-route-id="@cita.Id" class="btn btn-info btn-sm">Ver</a>
                                    <a asp-action="Edit" asp-route-id="@cita.Id" class="btn btn-warning btn-sm">Editar</a>
                                    <form asp-action="Delete" asp-route-id="@cita.Id" method="post" class="d-inline">
                                        <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('¿Eliminar esta cita?')">
                                            Eliminar
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <svg class="ui-icon ui-icon-lg text-muted" aria-hidden="true"><use href="#icon-calendar"></use></svg>
            <h3 class="mt-3">No hay citas para este paciente</h3>
            <p class="text-muted mb-4">Cuando se registre una cita, aparecerá aquí el historial completo.</p>
            <a asp-action="Index" class="btn btn-primary">Volver al listado</a>
        </div>
    }
</div>
