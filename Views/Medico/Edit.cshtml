@model CitasApp.Models.Medico

@{
    ViewData["Title"] = "Editar Médico";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg">
                <div class="card-header" style="background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);">
                    <h3 class="mb-0 text-white">
                        <i class="fas fa-user-md"></i> Editar Médico #@Model.Id
                    </h3>
                </div>
                <div class="card-body p-5">
                    <form method="post" novalidate>
                        <input type="hidden" name="id" value="@Model.Id" />

                        <div class="row mb-4">
                            <div class="col-md-6">
                                <label for="nombre" class="form-label">
                                    <i class="fas fa-user"></i> Nombre
                                </label>
                                <input type="text" class="form-control" id="nombre" name="nombre" value="@Model.Nombre" placeholder="Nombre del médico" required>
                                <span asp-validation-for="Nombre" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label for="apellido" class="form-label">
                                    <i class="fas fa-user"></i> Apellido
                                </label>
                                <input type="text" class="form-control" id="apellido" name="apellido" value="@Model.Apellido" placeholder="Apellido del médico" required>
                                <span asp-validation-for="Apellido" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label for="especialidad" class="form-label">
                                <i class="fas fa-briefcase-medical"></i> Especialidad
                            </label>
                            <input type="text" class="form-control" id="especialidad" name="especialidad" value="@Model.Especialidad" placeholder="Ej: Cardiología, Pediatría" required>
                            <span asp-validation-for="Especialidad" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label for="numeroLicencia" class="form-label">
                                <i class="fas fa-certificate"></i> Número de Licencia
                            </label>
                            <input type="text" class="form-control" id="numeroLicencia" name="numeroLicencia" value="@Model.NumeroLicencia" placeholder="Ej: CA-30117" required>
                            <span asp-validation-for="NumeroLicencia" class="text-danger"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary btn-lg flex-grow-1">
                                <i class="fas fa-save"></i> Guardar Cambios
                            </button>
                            <a href="@Url.Action("Index", "Medico")" class="btn btn-secondary btn-lg">
                                <i class="fas fa-times"></i> Cancelar
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>