@model IEnumerable<CitasApp.Models.Medico>

@{
    ViewData["Title"] = "Médicos";
}

<div class="container mt-5">
    <div class="header-section">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <i class="fas fa-stethoscope fa-2x mb-2" style="color: #11998e;"></i>
                <h1 class="mb-0">Directorio de Médicos</h1>
                <p class="text-muted mb-0">@Model.Count() médico(s) registrado(s)</p>
            </div>
            <a href="@Url.Action("Create", "Medico")" class="btn btn-success btn-lg">
                <i class="fas fa-plus"></i> Nuevo Médico
            </a>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th><i class="fas fa-hashtag"></i> Id</th>
                        <th><i class="fas fa-user"></i> Nombre</th>
                        <th><i class="fas fa-user"></i> Apellido</th>
                        <th><i class="fas fa-briefcase-medical"></i> Especialidad</th>
                        <th><i class="fas fa-certificate"></i> Licencia</th>
                        <th><i class="fas fa-cog"></i> Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var medico in Model)
                    {
                        <tr>
                            <td><strong>#@medico.Id</strong></td>
                            <td>@medico.Nombre</td>
                            <td>@medico.Apellido</td>
                            <td>
                                <span class="badge" style="background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);">
                                    @medico.Especialidad
                                </span>
                            </td>
                            <td><code>@medico.NumeroLicencia</code></td>
                            <td>
                                <a href="@Url.Action("Edit", "Medico", new { id = medico.Id })" class="btn btn-sm btn-warning" title="Editar">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <form method="post" action="@Url.Action("Delete", "Medico")" style="display:inline;">
                                    <input type="hidden" name="id" value="@medico.Id" />
                                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('¿Está seguro que desea eliminar este médico?')" title="Eliminar">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center py-5">
            <i class="fas fa-inbox fa-3x mb-3" style="color: #11998e;"></i>
            <h5>No hay médicos registrados</h5>
            <p class="mb-3">¡Comienza agregando tu primer médico!</p>
            <a href="@Url.Action("Create", "Medico")" class="btn btn-primary">
                <i class="fas fa-plus"></i> Registrar Médico
            </a>
        </div>
    }
</div>
