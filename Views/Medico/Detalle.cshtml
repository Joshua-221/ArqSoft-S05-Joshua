@model CitasApp.Models.Medico

@{
    ViewData["Title"] = "Detalle del Médico";
}

<div class="container mt-5">
    <h1>Detalle del Médico</h1>

    <div class="card mt-4">
        <div class="card-body">
            <div class="row mb-3">
                <div class="col-md-6">
                    <strong>Nombre:</strong>
                    <p>@Model.Nombre</p>
                </div>
                <div class="col-md-6">
                    <strong>Apellido:</strong>
                    <p>@Model.Apellido</p>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-6">
                    <strong>Especialidad:</strong>
                    <p>@Model.Especialidad</p>
                </div>
                <div class="col-md-6">
                    <strong>Número de Licencia:</strong>
                    <p>@Model.NumeroLicencia</p>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <a href="@Url.Action("Index", "Medico")" class="btn btn-secondary">Volver al Listado</a>
    </div>
</div>