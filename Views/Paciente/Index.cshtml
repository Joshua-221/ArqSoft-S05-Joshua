@model IEnumerable<CitasApp.Models.Paciente>

@{
    ViewData["Title"] = "Pacientes";
}

<div class="container mt-5">
    <div class="header-section">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <i class="fas fa-user-injured fa-2x mb-2" style="color: #764ba2;"></i>
                <h1 class="mb-0">Gestión de Pacientes</h1>
                <p class="text-muted mb-0">@Model.Count() paciente(s) registrado(s)</p>
            </div>
            <a href="@Url.Action("Create", "Paciente")" class="btn btn-success btn-lg">
                <i class="fas fa-plus"></i> Nuevo Paciente
            </a>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th><i class="fas fa-hashtag"></i> Id</th>
                        <th><i class="fas fa-user"></i> Nombre</th>
                        <th><i class="fas fa-user"></i> Apellido</th>
                        <th><i class="fas fa-envelope"></i> Email</th>
                        <th><i class="fas fa-phone"></i> Teléfono</th>
                        <th><i class="fas fa-cog"></i> Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var paciente in Model)
                    {
                        <tr>
                            <td><strong>#@paciente.Id</strong></td>
                            <td>@paciente.Nombre</td>
                            <td>@paciente.Apellido</td>
                            <td><a href="mailto:@paciente.Email">@paciente.Email</a></td>
                            <td><a href="tel:@paciente.Telefono">@paciente.Telefono</a></td>
                            <td>
                                <a href="@Url.Action("Edit", "Paciente", new { id = paciente.Id })" class="btn btn-sm btn-warning" title="Editar">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <form method="post" action="@Url.Action("Delete", "Paciente")" style="display:inline;">
                                    <input type="hidden" name="id" value="@paciente.Id" />
                                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('¿Está seguro que desea eliminar este paciente?')" title="Eliminar">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center py-5">
            <i class="fas fa-inbox fa-3x mb-3" style="color: #764ba2;"></i>
            <h5>No hay pacientes registrados</h5>
            <p class="mb-3">¡Comienza agregando tu primer paciente!</p>
            <a href="@Url.Action("Create", "Paciente")" class="btn btn-primary">
                <i class="fas fa-plus"></i> Registrar Paciente
            </a>
        </div>
    }
</div>
