@model CitasApp.Models.Paciente

@{
    ViewData["Title"] = "Editar Paciente";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg">
                <div class="card-header" style="background: linear-gradient(135deg, #764ba2 0%, #667eea 100%);">
                    <h3 class="mb-0 text-white">
                        <i class="fas fa-user-edit"></i> Editar Paciente #@Model.Id
                    </h3>
                </div>
                <div class="card-body p-5">
                    <form method="post" novalidate>
                        <input type="hidden" name="id" value="@Model.Id" />

                        <div class="row mb-4">
                            <div class="col-md-6">
                                <label for="nombre" class="form-label">
                                    <i class="fas fa-user"></i> Nombre
                                </label>
                                <input type="text" class="form-control" id="nombre" name="nombre" value="@Model.Nombre" placeholder="Nombre del paciente" required>
                                <span asp-validation-for="Nombre" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label for="apellido" class="form-label">
                                    <i class="fas fa-user"></i> Apellido
                                </label>
                                <input type="text" class="form-control" id="apellido" name="apellido" value="@Model.Apellido" placeholder="Apellido del paciente" required>
                                <span asp-validation-for="Apellido" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label for="email" class="form-label">
                                <i class="fas fa-envelope"></i> Email
                            </label>
                            <input type="email" class="form-control" id="email" name="email" value="@Model.Email" placeholder="correo@ejemplo.com" required>
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label for="telefono" class="form-label">
                                <i class="fas fa-phone"></i> Teléfono
                            </label>
                            <input type="tel" class="form-control" id="telefono" name="telefono" value="@Model.Telefono" placeholder="555-0000" required>
                            <span asp-validation-for="Telefono" class="text-danger"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary btn-lg flex-grow-1">
                                <i class="fas fa-save"></i> Guardar Cambios
                            </button>
                            <a href="@Url.Action("Index", "Paciente")" class="btn btn-secondary btn-lg">
                                <i class="fas fa-times"></i> Cancelar
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>